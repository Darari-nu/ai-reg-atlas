{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "update.schema.json",
  "title": "UpdateFeed",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "date", "country", "axis", "change_type", "title", "summary", "so_what", "impact", "sources", "country_anchor"],
    "properties": {
      "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z]{2}-\\d{3}$" },
      "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "country": { "type": "string", "pattern": "^[a-z]{2}$" },
      "axis": {
        "enum": ["risk_classification", "prohibited_uses", "gpai_obligations", "transparency", "penalties", "enforcement_body", "timeline", "general"]
      },
      "change_type": {
        "enum": ["new_regulation", "status_change", "guideline_draft", "deadline_change", "diff_change", "other"]
      },
      "title": { "type": "string", "minLength": 1, "maxLength": 120 },
      "summary": {
        "type": "object",
        "additionalProperties": false,
        "required": ["what", "who", "when_impact"],
        "properties": {
          "what": { "type": "string", "maxLength": 120 },
          "who": { "type": "string", "maxLength": 120 },
          "when_impact": { "type": "string", "maxLength": 120 }
        }
      },
      "detail": { "type": "string" },
      "so_what": { "type": "string", "minLength": 1 },
      "impact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["diff_changed"],
        "properties": {
          "diff_changed": { "type": "boolean" },
          "diff_note": { "type": "string" }
        }
      },
      "sources": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri" } },
      "country_anchor": { "type": "string" }
    }
  }
}
