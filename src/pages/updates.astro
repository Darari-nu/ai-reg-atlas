---
import LightLayout from '../layouts/LightLayout.astro';
import UpdateCard from '../components/UpdateCard.astro';
import {
  getCountries,
  getUpdates,
  AXIS_LABELS,
  CHANGE_TYPE_LABELS,
} from '../lib/data';

const countries = getCountries();
const countryMap = Object.fromEntries(countries.map((c) => [c.code, c]));
const updates = getUpdates();

const months = [...new Set(updates.map((u) => u.date.slice(0, 7)))];
const usedAxes = [...new Set(updates.map((u) => u.axis))];
const usedTypes = [...new Set(updates.map((u) => u.change_type))];
const usedCountries = [...new Set(updates.map((u) => u.country))];
---

<LightLayout title="更新アーカイブ | AI Reg Atlas">
  <main class="mx-auto max-w-4xl px-5 py-8">
    <h1 class="font-display text-2xl font-semibold">更新アーカイブ</h1>
    <p class="mt-2 text-sm text-ink/70">日次巡回で検知した「変化」の記録。フィルターと検索はブラウザ内で完結。</p>

    <!-- フィルターチップ（トグル・複数選択可） -->
    <div id="filters" class="mt-6 space-y-2">
      <div class="flex flex-wrap gap-1.5" data-group="country">
        {usedCountries.map((cc) => (
          <button type="button" class="chip border border-ink/25 bg-white px-2 py-1 text-xs" data-value={cc}>
            {countryMap[cc]?.flag} {countryMap[cc]?.name_ja}
          </button>
        ))}
      </div>
      <div class="flex flex-wrap gap-1.5" data-group="axis">
        {usedAxes.map((a) => (
          <button type="button" class="chip border border-ink/25 bg-white px-2 py-1 text-xs" data-value={a}>
            {AXIS_LABELS[a] ?? a}
          </button>
        ))}
      </div>
      <div class="flex flex-wrap gap-1.5" data-group="type">
        {usedTypes.map((t) => (
          <button type="button" class="chip border border-ink/25 bg-white px-2 py-1 text-xs" data-value={t}>
            {CHANGE_TYPE_LABELS[t] ?? t}
          </button>
        ))}
      </div>
      <input
        id="search-box"
        type="search"
        placeholder="フリーワード検索（タイトル・要約）"
        class="mt-2 w-full max-w-md border border-ink/25 bg-white px-3 py-2 text-sm placeholder:text-ink/40"
      />
    </div>

    <!-- 月別グループ -->
    {months.map((m) => (
      <section class="month-group mt-10" data-month={m}>
        <h2 class="font-mono text-sm font-medium text-ink/40">{m}</h2>
        <div class="mt-3 space-y-3">
          {updates.filter((u) => u.date.startsWith(m)).map((u) => (
            <UpdateCard update={u} country={countryMap[u.country]} theme="light" />
          ))}
        </div>
      </section>
    ))}

    <p id="no-hit" class="mt-10 hidden text-sm text-ink/50">条件に合う更新はない。</p>
  </main>
</LightLayout>

<script>
  // チップ複数選択 + フリーワードのAND絞り込み（クライアント内・DBレス §6-3）
  const active: Record<string, Set<string>> = { country: new Set(), axis: new Set(), type: new Set() };
  let word = '';

  const cards = [...document.querySelectorAll<HTMLElement>('details[data-country]')];
  const groups = [...document.querySelectorAll<HTMLElement>('#filters [data-group]')];
  const searchBox = document.getElementById('search-box') as HTMLInputElement;

  function apply() {
    let hits = 0;
    for (const card of cards) {
      const okCountry = active.country.size === 0 || active.country.has(card.dataset.country!);
      const okAxis = active.axis.size === 0 || active.axis.has(card.dataset.axis!);
      const okType = active.type.size === 0 || active.type.has(card.dataset.type!);
      const okWord = !word || (card.dataset.text ?? '').toLowerCase().includes(word);
      const show = okCountry && okAxis && okType && okWord;
      card.style.display = show ? '' : 'none';
      if (show) hits++;
    }
    // 空になった月見出しを隠す
    document.querySelectorAll<HTMLElement>('.month-group').forEach((g) => {
      const visible = [...g.querySelectorAll<HTMLElement>('details[data-country]')].some((c) => c.style.display !== 'none');
      g.style.display = visible ? '' : 'none';
    });
    document.getElementById('no-hit')!.classList.toggle('hidden', hits > 0);
  }

  for (const g of groups) {
    const name = g.dataset.group!;
    g.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const v = chip.dataset.value!;
        if (active[name].has(v)) {
          active[name].delete(v);
          chip.classList.remove('bg-ink', 'text-paper');
          chip.classList.add('bg-white');
        } else {
          active[name].add(v);
          chip.classList.remove('bg-white');
          chip.classList.add('bg-ink', 'text-paper');
        }
        apply();
      });
    });
  }

  searchBox?.addEventListener('input', () => {
    word = searchBox.value.trim().toLowerCase();
    apply();
  });
</script>
